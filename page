<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Retatrutide Pricing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#12161C;
    --ink-soft:#525C66;
    --ink-faint:#8A929B;
    --canvas:#FFFFFF;
    --mist:#F6F8F9;
    --mist-deep:#EFF3F4;
    --line:#E6EAED;
    --line-soft:#EEF1F3;
    --emerald:#0B6B54;
    --emerald-deep:#084C3C;
    --emerald-tint:#EAF3F0;
    --brass:#A9854E;
    --brass-deep:#8A6B3A;
    --brass-tint:#F8F3EA;
    --save:#1B7A47;
    --maxgrad-a:#13241F;
    --maxgrad-b:#0B6B54;
    --shadow-sm:0 1px 2px rgba(18,22,28,.04), 0 2px 8px rgba(18,22,28,.04);
    --shadow-md:0 4px 12px rgba(18,22,28,.06), 0 12px 32px rgba(18,22,28,.07);
    --shadow-lg:0 8px 24px rgba(11,107,84,.12), 0 24px 60px rgba(18,22,28,.14);
  }

  *{box-sizing:border-box;margin:0;padding:0}

  html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}

  body{
    font-family:'Inter',-apple-system,system-ui,sans-serif;
    color:var(--ink);
    background:
      radial-gradient(120% 60% at 50% -10%, #FBFCFC 0%, var(--mist) 46%, var(--mist-deep) 100%);
    line-height:1.5;
    font-size:16px;
    padding:0;
  }

  .sheet{
    max-width:1180px;
    margin:0 auto;
    padding:clamp(28px,5vw,72px) clamp(20px,4vw,56px) 64px;
  }

  /* ---------- shared type ---------- */
  .eyebrow{
    font-family:'Inter';
    font-weight:600;
    font-size:11.5px;
    letter-spacing:.24em;
    text-transform:uppercase;
    color:var(--emerald);
    display:flex;align-items:center;gap:12px;
  }
  .eyebrow::before{
    content:"";width:26px;height:1.5px;background:var(--emerald);display:inline-block;border-radius:2px;
  }
  .eyebrow.center{justify-content:center}
  .num{font-variant-numeric:tabular-nums;font-feature-settings:"tnum" 1}

  /* ---------- HERO ---------- */
  .hero{
    text-align:center;
    padding:clamp(24px,5vw,56px) 0 clamp(34px,5vw,58px);
    border-bottom:1px solid var(--line);
    position:relative;
  }
  .hero .kicker{
    font-family:'Inter';font-weight:600;font-size:12px;letter-spacing:.32em;
    text-transform:uppercase;color:var(--brass);margin-bottom:22px;
  }
  .hero h1{
    font-family:'Fraunces';
    font-optical-sizing:auto;
    font-weight:500;
    font-size:clamp(46px,9vw,104px);
    line-height:.96;
    letter-spacing:-.02em;
    color:var(--ink);
  }
  .hero .sub{
    font-family:'Fraunces';
    font-weight:400;
    font-style:italic;
    font-size:clamp(20px,3.4vw,30px);
    color:var(--emerald);
    margin-top:14px;
    letter-spacing:.01em;
  }
  .hero .descriptor{
    font-size:13px;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:var(--ink-faint);
    margin-top:24px;
    font-weight:500;
  }
  .hero .potency{
    display:inline-flex;align-items:center;gap:8px;
    margin-top:18px;padding:7px 16px;border:1px solid var(--line);border-radius:100px;
    background:var(--canvas);font-size:12.5px;font-weight:600;letter-spacing:.04em;color:var(--ink-soft);
    box-shadow:var(--shadow-sm);
  }
  .hero .potency b{color:var(--ink);font-weight:700}
  .valueprop{
    max-width:640px;margin:30px auto 0;
    font-size:clamp(16px,2.1vw,18.5px);
    line-height:1.62;color:var(--ink-soft);
  }
  .valueprop b{color:var(--ink);font-weight:600}

  /* ---------- SECTION SCAFFOLD ---------- */
  section{padding-top:clamp(46px,6vw,76px)}
  .sec-head{margin-bottom:30px}
  .sec-head h2{
    font-family:'Fraunces';font-weight:500;font-size:clamp(27px,4vw,40px);
    letter-spacing:-.015em;color:var(--ink);margin-top:14px;line-height:1.05;
  }
  .sec-head p{margin-top:12px;color:var(--ink-soft);font-size:15.5px;max-width:560px;line-height:1.6}

  /* ---------- PRICING CARDS ---------- */
  .cards{
    display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch;
  }
  .card{
    position:relative;
    background:var(--canvas);
    border:1px solid var(--line);
    border-radius:18px;
    padding:30px 24px 28px;
    display:flex;flex-direction:column;
    box-shadow:var(--shadow-sm);
    transition:transform .25s ease, box-shadow .25s ease;
  }
  .card .tier{
    font-family:'Inter';font-weight:600;font-size:12px;letter-spacing:.14em;
    text-transform:uppercase;color:var(--ink-soft);
  }
  .card .vials{
    font-size:14px;color:var(--ink-faint);margin-top:6px;font-weight:500;
  }
  .card .price{
    margin-top:26px;display:flex;align-items:baseline;gap:4px;
  }
  .card .price .amt{
    font-family:'Fraunces';font-weight:600;font-size:52px;letter-spacing:-.02em;line-height:1;color:var(--ink);
  }
  .card .price .per{font-size:13px;color:var(--ink-faint);font-weight:500;letter-spacing:.02em}
  .card .save{
    margin-top:auto;padding-top:22px;
  }
  .card .save .pill{
    display:inline-flex;align-items:center;gap:7px;
    font-size:13px;font-weight:600;letter-spacing:.01em;
    color:var(--save);background:var(--emerald-tint);
    padding:7px 13px;border-radius:100px;
  }
  .card .save .flat{
    font-size:13px;color:var(--ink-faint);font-weight:500;letter-spacing:.02em;
  }
  .card .badge{
    position:absolute;top:-12px;left:50%;transform:translateX(-50%);
    white-space:nowrap;
    font-size:10.5px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;
    padding:6px 14px;border-radius:100px;color:#fff;box-shadow:var(--shadow-sm);
  }
  /* Best value (20+) */
  .card.best{border-color:rgba(11,107,84,.35)}
  .card.best .badge{background:var(--emerald)}
  /* Maximum (30+) — the signature lift */
  .card.max{
    background:linear-gradient(168deg,var(--maxgrad-a) 0%, var(--emerald-deep) 58%, var(--emerald) 100%);
    border:none;
    transform:translateY(-14px);
    box-shadow:var(--shadow-lg);
    padding-top:34px;
  }
  .card.max .tier{color:var(--brass-tint)}
  .card.max .vials{color:rgba(255,255,255,.66)}
  .card.max .price .amt{color:#fff}
  .card.max .price .per{color:rgba(255,255,255,.6)}
  .card.max .badge{background:var(--brass);color:#fff;box-shadow:0 6px 18px rgba(169,133,78,.5)}
  .card.max .save .pill{background:rgba(255,255,255,.14);color:#fff}
  .card.max::after{
    content:"";position:absolute;inset:0;border-radius:18px;
    border:1px solid rgba(201,168,120,.4);pointer-events:none;
  }

  /* ---------- SMART BUY ---------- */
  .smart{background:transparent}
  .smart-wrap{
    background:var(--ink);
    border-radius:22px;
    padding:clamp(28px,4vw,46px);
    color:#fff;
    position:relative;
    overflow:hidden;
  }
  .smart-wrap::before{
    content:"";position:absolute;right:-120px;top:-120px;width:380px;height:380px;border-radius:50%;
    background:radial-gradient(circle, rgba(11,107,84,.55) 0%, transparent 70%);
  }
  .smart-wrap .eyebrow{color:var(--brass-soft,#C9A878)}
  .smart-wrap .eyebrow::before{background:var(--brass)}
  .smart-wrap h2{
    font-family:'Fraunces';font-weight:500;font-size:clamp(26px,3.6vw,38px);
    margin-top:14px;letter-spacing:-.015em;color:#fff;position:relative;
  }
  .smart-wrap .lead{
    color:rgba(255,255,255,.66);margin-top:12px;font-size:15.5px;max-width:600px;line-height:1.6;position:relative;
  }
  .swaps{
    margin-top:34px;display:grid;grid-template-columns:repeat(3,1fr);gap:16px;position:relative;
  }
  .swap{
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.1);
    border-radius:16px;padding:24px 22px;
    backdrop-filter:blur(4px);
  }
  .swap .row{display:flex;justify-content:space-between;align-items:baseline}
  .swap .lab{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5);font-weight:600}
  .swap .from{margin-top:8px;display:flex;align-items:baseline;gap:8px;color:rgba(255,255,255,.55)}
  .swap .from .q{font-size:15px;font-weight:500}
  .swap .from .p{font-family:'Fraunces';font-size:21px;font-weight:500;text-decoration:line-through;text-decoration-color:rgba(255,255,255,.3)}
  .swap .arrow{height:1px;background:linear-gradient(90deg,var(--brass),transparent);margin:16px 0;position:relative}
  .swap .arrow::after{content:"↓";position:absolute;left:-2px;top:-11px;color:var(--brass-soft,#C9A878);font-size:14px}
  .swap .to{display:flex;align-items:baseline;gap:8px}
  .swap .to .q{font-size:16px;font-weight:600;color:#fff}
  .swap .to .p{font-family:'Fraunces';font-size:30px;font-weight:600;color:#fff;letter-spacing:-.01em}
  .swap .result{
    margin-top:18px;display:flex;align-items:center;justify-content:space-between;gap:10px;
    padding-top:16px;border-top:1px solid rgba(255,255,255,.1);
  }
  .swap .result .plus{font-size:13px;font-weight:600;color:var(--brass-soft,#C9A878);letter-spacing:.02em}
  .swap .result .amt{
    font-size:14px;font-weight:700;color:#fff;background:var(--emerald);
    padding:5px 12px;border-radius:100px;letter-spacing:.01em;
  }

  /* ---------- FULL TABLE ---------- */
  .table-wrap{
    border:1px solid var(--line);border-radius:18px;overflow:hidden;background:var(--canvas);
    box-shadow:var(--shadow-sm);
  }
  table{width:100%;border-collapse:collapse;font-variant-numeric:tabular-nums}
  thead th{
    background:var(--ink);color:#fff;
    font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
    padding:16px 22px;text-align:right;
  }
  thead th:first-child{text-align:left}
  tbody td{
    padding:13px 22px;text-align:right;font-size:15px;border-bottom:1px solid var(--line-soft);
    color:var(--ink);
  }
  tbody td:first-child{text-align:left;font-weight:600}
  tbody tr:nth-child(even){background:var(--mist)}
  tbody td .tiername{font-size:13px;color:var(--ink-soft);font-weight:500}
  tbody td .perv{font-weight:600}
  tbody td .savecell{color:var(--save);font-weight:600}
  tbody td .flatcell{color:var(--ink-faint);font-weight:500}

  tr.band td{
    background:var(--emerald-tint);
    text-align:left;
    padding:11px 22px;
    font-size:11.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--emerald-deep);
    border-bottom:1px solid rgba(11,107,84,.14);
  }
  tr.band.brass td{background:var(--brass-tint);color:var(--brass-deep);border-bottom-color:rgba(169,133,78,.2)}
  tr.milestone td{background:#fff;}
  tr.milestone td:first-child{position:relative}
  tr.milestone td .dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--emerald);margin-right:9px;vertical-align:middle}
  tr.milestone.brass td .dot{background:var(--brass)}
  tr.milestone td, tr.milestone td .perv{font-weight:700}

  /* ---------- 10MG QUIET STRIP ---------- */
  .alt{
    margin-top:30px;display:flex;flex-wrap:wrap;align-items:center;gap:18px 28px;
    padding:20px 26px;border:1px dashed var(--line);border-radius:14px;background:rgba(246,248,249,.6);
  }
  .alt .label{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-faint);font-weight:600}
  .alt .opt{display:flex;align-items:baseline;gap:8px;font-size:14px;color:var(--ink-soft)}
  .alt .opt b{font-family:'Fraunces';font-size:18px;font-weight:600;color:var(--ink)}
  .alt .note{font-size:12.5px;color:var(--ink-faint);font-style:italic;margin-left:auto}

  /* ---------- CTA ---------- */
  .cta{
    margin-top:clamp(46px,6vw,76px);
    text-align:center;
    background:linear-gradient(168deg,#FBFCFC,var(--mist));
    border:1px solid var(--line);
    border-radius:22px;
    padding:clamp(38px,5vw,60px) clamp(24px,4vw,48px);
  }
  .cta h2{
    font-family:'Fraunces';font-weight:500;font-size:clamp(24px,3.4vw,34px);
    letter-spacing:-.015em;max-width:620px;margin:14px auto 0;line-height:1.18;
  }
  .cta p{max-width:540px;margin:16px auto 0;color:var(--ink-soft);font-size:16px;line-height:1.62}
  .assurances{
    margin-top:30px;display:flex;flex-wrap:wrap;justify-content:center;gap:12px;
  }
  .assurances .item{
    display:inline-flex;align-items:center;gap:9px;
    background:var(--canvas);border:1px solid var(--line);border-radius:100px;
    padding:10px 18px;font-size:13.5px;font-weight:600;color:var(--ink);box-shadow:var(--shadow-sm);
  }
  .assurances .item .ck{
    width:18px;height:18px;border-radius:50%;background:var(--emerald);color:#fff;
    display:inline-flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;
  }

  /* ---------- FOOTER ---------- */
  footer{
    margin-top:48px;padding-top:26px;border-top:1px solid var(--line);
    text-align:center;
  }
  footer .ruo{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-faint);font-weight:600;line-height:1.9}

  /* ---------- entrance motion (restrained) ---------- */
  @media (prefers-reduced-motion:no-preference){
    .reveal{opacity:0;transform:translateY(14px);animation:rise .7s cubic-bezier(.22,.61,.36,1) forwards}
    .hero .kicker{animation-delay:.02s}
    .hero h1{animation-delay:.08s}
    .hero .sub{animation-delay:.16s}
    .hero .descriptor{animation-delay:.22s}
    .hero .potency{animation-delay:.28s}
    .valueprop{animation-delay:.34s}
    @keyframes rise{to{opacity:1;transform:none}}
  }

  /* ---------- RESPONSIVE / MOBILE ---------- */
  @media (max-width:920px){
    .cards{grid-template-columns:repeat(2,1fr);gap:16px}
    .card.max{transform:none}
    .swaps{grid-template-columns:1fr;gap:14px}
  }
  @media (max-width:560px){
    body{font-size:15px}
    .sheet{padding:24px 18px 48px}
    .cards{grid-template-columns:1fr;gap:26px}
    .card.max{transform:none;order:-1}
    .card .price .amt{font-size:48px}
    /* collapse table to essential columns on small screens */
    thead th.hide-sm, tbody td.hide-sm{display:none}
    thead th, tbody td{padding:12px 16px;font-size:14px}
    .alt{flex-direction:column;align-items:flex-start;gap:12px}
    .alt .note{margin-left:0}
    .assurances{flex-direction:column;align-items:stretch}
    .assurances .item{justify-content:center}
  }

  /* ---------- PRINT / PDF ---------- */
  @page{size:A4;margin:14mm}
  @media print{
    body{background:#fff}
    .sheet{max-width:none;padding:0}
    .reveal{opacity:1!important;transform:none!important;animation:none!important}
    .card,.swap,.table-wrap,.cta,tr,.alt{box-shadow:none!important}
    .card.max{transform:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
    section{page-break-inside:avoid}
    .smart-wrap,.table-wrap{page-break-inside:avoid}
    tr{page-break-inside:avoid}
    .cta{page-break-inside:avoid}
  }
</style>
</head>
<body>
<div class="sheet">

  <!-- ===================== HERO ===================== -->
  <header class="hero">
    <div class="kicker reveal">Premium Volume Pricing</div>
    <h1 class="reveal">Retatrutide<br>Pricing</h1>
    <div class="sub reveal">GLP-1 / GIP / Glucagon Triple Agonist</div>
    <div class="descriptor reveal">Research Peptide</div>
    <div><span class="potency reveal">Potency&nbsp;·&nbsp;<b>30&nbsp;mg</b>&nbsp;per&nbsp;vial</span></div>
    <p class="valueprop reveal">Pricing rewards larger orders.</p>
  </header>

  <!-- ===================== PRICING TIERS ===================== -->
  <section>
    <div class="sec-head">
      <div class="eyebrow">Pricing Tiers</div>
      <h2>One product. Four price points.</h2>
      <p>The more vials in your order, the lower your cost per vial. No codes, no negotiation — the discount is built in.</p>
    </div>

    <div class="cards">
      <!-- Standard -->
      <div class="card">
        <div class="tier">Standard</div>
        <div class="vials">1–9 Vials</div>
        <div class="price"><span class="amt num">$300</span><span class="per">/ vial</span></div>
        <div class="save"><span class="flat">Standard rate</span></div>
      </div>

      <!-- Bulk -->
      <div class="card">
        <div class="tier">Bulk Savings</div>
        <div class="vials">10–19 Vials</div>
        <div class="price"><span class="amt num">$250</span><span class="per">/ vial</span></div>
        <div class="save"><span class="pill">Save 17%</span></div>
      </div>

      <!-- Wholesale (Best Value) -->
      <div class="card best">
        <span class="badge">Best Value</span>
        <div class="tier">Wholesale</div>
        <div class="vials">20–29 Vials</div>
        <div class="price"><span class="amt num">$200</span><span class="per">/ vial</span></div>
        <div class="save"><span class="pill">Save 33%</span></div>
      </div>

      <!-- Maximum (signature) -->
      <div class="card max">
        <span class="badge">Maximum Savings</span>
        <div class="tier">Maximum</div>
        <div class="vials">30+ Vials</div>
        <div class="price"><span class="amt num">$150</span><span class="per">/ vial</span></div>
        <div class="save"><span class="pill">Save 50%</span></div>
      </div>
    </div>
  </section>

  <!-- ===================== SMART BUY ===================== -->
  <section class="smart">
    <div class="smart-wrap">
      <div class="eyebrow">Smart Buy Opportunities</div>
      <h2>Sometimes one more vial costs you less.</h2>
      <p class="lead">At each tier threshold, adding a single vial moves your whole order into the next price bracket — so you receive more product for a lower total. The math below is exact.</p>

      <div class="swaps">
        <!-- 9 -> 10 -->
        <div class="swap">
          <div class="lab">Threshold · 10</div>
          <div class="from"><span class="q num">9 vials</span><span class="p num">$2,700</span></div>
          <div class="arrow"></div>
          <div class="to"><span class="q num">10 vials</span><span class="p num">$2,500</span></div>
          <div class="result"><span class="plus">+1 vial included</span><span class="amt num">Save $200</span></div>
        </div>

        <!-- 19 -> 20 -->
        <div class="swap">
          <div class="lab">Threshold · 20</div>
          <div class="from"><span class="q num">19 vials</span><span class="p num">$4,750</span></div>
          <div class="arrow"></div>
          <div class="to"><span class="q num">20 vials</span><span class="p num">$4,000</span></div>
          <div class="result"><span class="plus">+1 vial included</span><span class="amt num">Save $750</span></div>
        </div>

        <!-- 29 -> 30 -->
        <div class="swap">
          <div class="lab">Threshold · 30</div>
          <div class="from"><span class="q num">29 vials</span><span class="p num">$5,800</span></div>
          <div class="arrow"></div>
          <div class="to"><span class="q num">30 vials</span><span class="p num">$4,500</span></div>
          <div class="result"><span class="plus">+1 vial included</span><span class="amt num">Save $1,300</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FULL TABLE ===================== -->
  <section>
    <div class="sec-head">
      <div class="eyebrow">Complete Pricing</div>
      <h2>Every quantity, priced out.</h2>
      <p>Per-vial pricing and your total savings against the standard rate. Tier changes are marked as you scan down.</p>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Vials</th>
            <th class="hide-sm">Tier</th>
            <th>Per Vial</th>
            <th>Total</th>
            <th>You Save</th>
          </tr>
        </thead>
        <tbody>
          <!-- STANDARD 1-9 -->
          <tr><td>1</td><td class="hide-sm"><span class="tiername">Standard</span></td><td class="perv">$300</td><td class="num">$300</td><td class="flatcell">Standard rate</td></tr>
          <tr><td>2</td><td class="hide-sm"><span class="tiername">Standard</span></td><td class="perv">$300</td><td class="num">$600</td><td class="flatcell">Standard rate</td></tr>
          <tr><td>3</td><td class="hide-sm"><span class="tiername">Standard</span></td><td class="perv">$300</td><td class="num">$900</td><td class="flatcell">Standard rate</td></tr>
